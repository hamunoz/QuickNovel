<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="?attr/primaryBlackBackground">

    <!-- Tab Layout -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/filter_tabs"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:background="?attr/primaryBlackBackground"
        app:tabGravity="fill"
        app:tabMode="fixed"
        app:tabIndicatorColor="?attr/colorAccent"
        app:tabSelectedTextColor="?attr/colorAccent"
        app:tabTextColor="?attr/grayTextColor"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TabNoCaps"
        app:tabBackground="@drawable/tab_background_dark" />

    <!-- Content Frame -->
    <FrameLayout
        android:id="@+id/tab_content"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Filter Tab Content -->
        <LinearLayout
            android:id="@+id/filter_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <CheckBox
                android:id="@+id/filter_downloaded"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/downloaded"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:buttonTint="?attr/colorAccent"
                android:paddingVertical="12dp"
                android:checked="false" />

            <CheckBox
                android:id="@+id/filter_unread"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unread"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:buttonTint="?attr/colorAccent"
                android:paddingVertical="12dp"
                android:checked="false" />

            <CheckBox
                android:id="@+id/filter_bookmarked"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/bookmarks"
                android:textColor="?attr/textColor"
                android:textSize="16sp"
                android:buttonTint="?attr/colorAccent"
                android:paddingVertical="12dp"
                android:checked="false" />

        </LinearLayout>

        <!-- Sort Tab Content -->
        <LinearLayout
            android:id="@+id/sort_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <LinearLayout
                android:id="@+id/sort_by_source"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:background="?android:attr/selectableItemBackground"
                android:clickable="true"
                android:focusable="true"
                android:paddingVertical="16dp"
                android:paddingHorizontal="4dp">

                <ImageView
                    android:id="@+id/sort_source_arrow"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_baseline_arrow_upward_24"
                    app:tint="?attr/colorAccent"
                    android:layout_marginEnd="12dp"
                    android:visibility="visible" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/sort_by_source"
                    android:textColor="?attr/textColor"
                    android:textSize="16sp" />

            </LinearLayout>



        </LinearLayout>

        <!-- Display Tab Content (placeholder for now) -->
        <LinearLayout
            android:id="@+id/display_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Display options coming soon"
                android:textColor="?attr/grayTextColor"
                android:textSize="16sp"
                android:gravity="center"
                android:paddingVertical="32dp" />

        </LinearLayout>

    </FrameLayout>

</LinearLayout> 
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="?attr/primaryBlackBackground">

    <TextView
            android:text="@string/read_action_chapters"
            android:paddingStart="?android:attr/listPreferredItemPaddingStart"
            android:paddingEnd="?android:attr/listPreferredItemPaddingEnd"
            android:layout_marginTop="20dp"
            android:layout_marginBottom="10dp"
            android:textStyle="bold"
            android:textSize="20sp"
            android:textColor="?attr/textColor"
            android:layout_width="match_parent"
            android:layout_rowWeight="1"
            android:paddingTop="10dp"
            android:layout_height="wrap_content" />

    <com.google.android.material.tabs.TabLayout
            android:id="@+id/filter_tabs"
            style="@style/Theme.Widget.Tabs"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_gravity="bottom"
            android:background="?attr/primaryBlackBackground"
            android:descendantFocusability="blocksDescendants"
            android:focusable="false"
            android:paddingHorizontal="5dp"
            app:layout_scrollFlags="noScroll"
            app:tabGravity="start"
            app:tabIndicator="@drawable/indicator_background"
            app:tabIndicatorColor="?attr/white"
            app:tabIndicatorGravity="center"
            app:tabIndicatorHeight="30dp"
            app:tabMaxWidth="0dp"
            app:tabMinWidth="120dp"
            app:tabMode="scrollable"
            app:tabSelectedTextColor="?attr/primaryBlackBackground"
            app:tabTextAppearance="@style/TabNoCaps"
            app:tabTextColor="?attr/textColor" />

    <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

        <LinearLayout
                tools:visibility="gone"
                android:id="@+id/filter_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:visibility="visible">

            <com.google.android.material.checkbox.MaterialCheckBox
                    style="@style/WhiteCheckmark"
                    tools:checked="true"
                    android:id="@+id/filter_downloaded"
                    android:text="@string/downloaded" />

            <com.google.android.material.checkbox.MaterialCheckBox
                    style="@style/WhiteCheckmark"
                    tools:checked="true"
                    android:id="@+id/filter_read"
                    android:text="@string/read" />

            <com.google.android.material.checkbox.MaterialCheckBox
                    style="@style/WhiteCheckmark"
                    tools:checked="true"
                    android:id="@+id/filter_unread"
                    android:text="@string/unread" />

            <com.google.android.material.checkbox.MaterialCheckBox
                    android:visibility="gone"
                    style="@style/WhiteCheckmark"
                    tools:checked="true"
                    android:id="@+id/filter_bookmarked"
                    android:text="@string/bookmarks" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                android:id="@+id/sort_content"
                tools:visibility="visible"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

        </androidx.recyclerview.widget.RecyclerView>

        <!--<LinearLayout
                android:id="@+id/sort_content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                tools:visibility="visible"
                android:visibility="gone">

            <TextView
                    android:id="@+id/sort_by_source"
                    style="@style/CheckLabel"
                    android:text="@string/chapter_sort" />

            <TextView
                    android:id="@+id/sort_by_last_read"
                    style="@style/CheckLabel"
                    android:text="@string/recently_updated_sort" />
        </LinearLayout>-->
    </FrameLayout>
</LinearLayout>
